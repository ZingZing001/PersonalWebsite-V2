# EmailJS Configuration
# Get these values from https://dashboard.emailjs.com/

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# Ask Virtual Johnson chat endpoint
# Points to the deployed Cloudflare Worker in /worker.
# Local dev: http://localhost:8787/chat
# Production: https://ask-johnson.<your-subdomain>.workers.dev/chat
VITE_CHAT_API_URL=http://localhost:8787/chat

# Required only when running `npm run embed` (the build-embeddings script).
# Get a key at https://www.voyageai.com/
# VOYAGE_API_KEY=pa-...
